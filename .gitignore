# ============================================================
#  SimpliFly — Root .gitignore
#  RULE: This file tells Git what to NEVER upload to GitHub.
#  The most important ones are .env files (they hold passwords!)
# ============================================================

# --- Environment Variables (YOUR PASSWORDS — NEVER COMMIT THESE) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# --- Next.js Build Output ---
.next/
out/
build/
dist/

# --- OS Files (junk your computer creates) ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE Files ---
.vscode/settings.json
.idea/
*.swp
*.swo

# --- Docker ---
.docker/

# --- Logs ---
logs/
*.log

# --- TypeScript ---
*.tsbuildinfo

# --- Testing ---
coverage/
.nyc_output/

# --- Prisma ---
# (schema.prisma IS committed, but generated client is not)
backend/src/generated/

# --- SSL Certificates (if any local ones) ---
*.pem
*.key
*.crt
