# ==============================================================
#  backend/.env.example — Template for Environment Variables
#
#  HOW TO USE:
#  1. Copy this file: cp .env.example .env
#  2. Fill in your real values
#  3. NEVER commit .env to Git (it's in .gitignore)
#
#  Think of .env as your app's "secret notebook".
#  .env.example is the empty template notebook you share.
# ==============================================================

# ── Server ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database (PostgreSQL) ──────────────────────────────────────
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
# For local dev (Docker): use the values from docker-compose.dev.yml
DATABASE_URL=postgresql://simplifly:devpassword123@localhost:5432/simplifly_dev

# ── JWT Authentication ─────────────────────────────────────────
# Generate a secret: run `openssl rand -hex 64` in your terminal
# This MUST be a long, random string. Never use simple words.
JWT_SECRET=REPLACE_WITH_64_CHARACTER_RANDOM_STRING
JWT_EXPIRES_IN=7d

# ── Redis ──────────────────────────────────────────────────────
# For local dev (Docker): redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ── Cloudinary (Image Storage) ─────────────────────────────────
# Get these from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Resend (Email Service) ─────────────────────────────────────
# Get this from: https://resend.com → API Keys
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=SimpliFly <no-reply@simpliflyfinland.fi>

# ── Security ───────────────────────────────────────────────────
# Your frontend URL (for CORS whitelist)
FRONTEND_URL=http://localhost:3000

# ── Database Password (used by docker-compose) ─────────────────
POSTGRES_PASSWORD=devpassword123
REDIS_PASSWORD=devredispassword123
